model Tag {
  id              String @id @default(uuid())

  type            TagType

  name            String
  slug            String @unique

  displayOrder    Int @default(0)

  isActive        Boolean @default(true)

  designs         DesignTag[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([isActive])

  @@map("tags")
}
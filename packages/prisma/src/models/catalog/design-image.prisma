model DesignImage {
  id              String @id @default(uuid())

  designId        String

  imageUrl        String
  altText         String?

  displayOrder    Int @default(0)

  design          Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([designId])

  @@map("design_images")
}
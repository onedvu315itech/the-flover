model Category {
  id              String @id @default(uuid())

  name            String
  slug            String @unique

  description     String?

  displayOrder    Int @default(0)

  isActive        Boolean @default(true)

  designs         Design[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])

  @@map("categories")
}
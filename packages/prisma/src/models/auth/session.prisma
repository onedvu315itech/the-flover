model Session {
  id          String @id @default(uuid())

  userId      String

  token       String @unique

  ipAddress   String?
  userAgent   String?

  expiresAt   DateTime

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])

  @@map("sessions")
}
{
  "name": "@repo/prisma",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:schema": "tsx build-schema.ts",
    "generate": "pnpm build:schema && prisma generate",
    "push": "pnpm build:schema && prisma db push",
    "seed": "tsx src/seeds/index.ts",
    "db:setup": "pnpm generate && pnpm push && pnpm seed",
    "reset": "pnpm build:schema && prisma db push --force-reset && tsx src/seeds/index.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.9.0",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1"
  }
}